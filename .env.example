APP_NAME="CCS Yacht"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

# System Admin Configuration
SYSTEM_ADMIN_NAME="System Admin"
SYSTEM_ADMIN_ACTOR_NAME="Papertrail Marine"

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database - Docker configuration
# Central database (landlord) for tenant management
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=ccsyacht_central
DB_USERNAME=ccsyacht
DB_PASSWORD=secret

# Tenant database prefix (tenant databases: tenant_<uuid>)
TENANCY_DATABASE_PREFIX=tenant_

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

# Redis - Docker configuration
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379

# # Mail Configuration
# # For local development, use mailpit (MAIL_MAILER=smtp)
# # For production, use postmark (MAIL_MAILER=postmark)
# MAIL_MAILER=smtp
# MAIL_HOST=mailpit
# MAIL_PORT=1025
# MAIL_USERNAME=null
# MAIL_PASSWORD=null
# MAIL_ENCRYPTION=null
# MAIL_FROM_ADDRESS="noreply@ccsyacht.com"
# MAIL_FROM_NAME="${APP_NAME}"

# Postmark
MAIL_MAILER=postmark
POSTMARK_TOKEN=

# Email branding logo (must be an absolute URL)
MAIL_LOGO_URL="${APP_URL}/images/logo.png"

VITE_APP_NAME="${APP_NAME}"
